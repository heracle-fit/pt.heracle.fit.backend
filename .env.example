# Heracle Fitness Backend (Go)
PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname

JWT_SECRET=change-me

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_123

# Firebase Service Account
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI API Keys
OPENAI_API=
GEMINI_API=
HUGGINGFACE_API=

# Per-feature AI provider: openai | gemini | huggingface
FOOD_ANALYSE_PROVIDER=gemini
FOOD_ANALYSE_MODEL=gemini-1.5-flash

DIET_SUGGESTION_PROVIDER=huggingface
DIET_SUGGESTION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

SLEEP_INSIGHT_PROVIDER=huggingface
SLEEP_INSIGHT_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
